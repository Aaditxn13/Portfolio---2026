        },
        {
          "uid": "b8f3qpt00",
          "type": "feature-1",
          "headline": "Spotlight Banners",
          "body": "Variants for active campaigns, general IPL theming, and no-load fallbacks.",
          "media": {
            "type": "image",
            "src": "",
            "alt": "",
            "uid": "b44j5kelf"
          },
          "reverse": false
        },
        {
          "uid": "bmqc7gof0",
          "type": "spacer",
          "size": "md"
        },
        {
          "uid": "bffwdwmqg",
          "type": "eyebrow-heading",
          "eyebrow": "",
          "headline": "Jeeto Dhan Dhana Dhan"
        },
        {
          "uid": "b7ula2g95",
          "type": "text",
          "body": "A Jio-partnered campaign where users answered cricket questions on JioCinema to win prizes on PayZapp. We designed the in-app landing, the reward state, and the fallback for users who hit onboarding errors — a ₹50 SmartBuy voucher so no attempt felt wasted."
        },
        {
          "uid": "bwl177cs9",
          "type": "image",
          "layout": "wide",
          "src": "cs-asset:now-and-me:1782837662005:bnk73xc04",
          "alt": "JDDD",
          "mediaType": "image",
          "mediaMimeType": "image/jpeg",
          "localAsset": {
            "status": "local",
            "field": "src",
            "originalName": "JDDD.jpg",
            "mimeType": "image/jpeg",
            "size": 114041,
            "resourceType": "image",

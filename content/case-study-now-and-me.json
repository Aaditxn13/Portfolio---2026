          },
          "items": null
        },
        {
          "uid": "bg7x82b5e",
          "type": "spacer",
          "size": "md"
        },
        {
          "uid": "b8vt5eqay",
          "type": "eyebrow-heading",
          "eyebrow": "",
          "headline": "Score & Win"
        },
        {
          "uid": "by2w8jbat",
          "type": "text",
          "body": "Users earned runs through payments, tap-and-pay, bill payments, and referrals. We designed the leaderboard, the runs widget, and the overlay — everything that made the scoring logic visible and worth caring about."
        },
        {
          "uid": "bgnjjijdq",

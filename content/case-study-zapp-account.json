              "createdAt": "2026-06-27T17:30:21.015Z"
            }
          },
          "uid": "bhorizontal-pzhw-1",
          "reverse": true
        },
        {
          "uid": "brvsdrc2i",
          "type": "spacer",
          "size": "md"
        }
      ],
      "uid": "bckbteed9"
    },

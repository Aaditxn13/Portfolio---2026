    {
      "id": "next-phase",
      "label": "Next Phase",
      "blocks": [
        {
          "type": "section-label",
          "label": "Next phase",
          "uid": "b4ssdm3om"
        },
        {
          "type": "eyebrow-heading",
          "eyebrow": "",
          "headline": "What we planned further",
          "uid": "bkpmf09cz"
        },
        {
          "type": "text",
          "body": "The product had more potential than what launched. During the process, we explored several directions — new features, deeper functionality, and ideas that could meaningfully grow the product. Some made it in, many didn't. Priorities shifted, timelines tightened, and v1 had to stay focused.",
          "uid": "blb56sblk"
        },
        {
          "uid": "beaxfsxcl",
          "type": "image",
          "layout": "wide",
          "src": "cs-asset:zapp-account:1782584950486:by1cc30p3",
